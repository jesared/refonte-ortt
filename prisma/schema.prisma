generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  USER
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  updatedAt DateTime @updatedAt
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  url       String   @unique
  name      String
  createdAt DateTime @default(now())
}
