generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  updatedAt DateTime @updatedAt
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  url       String   @unique
  name      String
  createdAt DateTime @default(now())
}
